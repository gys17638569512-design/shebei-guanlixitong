# 数据库连接
DATABASE_URL=sqlite:///./crane_mms.db

# JWT密钥
SECRET_KEY=your_secret_key_1234567890

# 腾讯云COS配置
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-beijing

# e签宝配置
ESIGN_MOCK=true
ESIGN_APP_ID=
ESIGN_APP_SECRET=

# 其他配置
DEBUG=true

# 阶段二：短信服务（阿里云短信）
# 登录 https://dysms.console.aliyun.com/ 申请后填入以下配置
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=数字化起重机维修维保系统
SMS_TEMPLATE_CODE_DISPATCH=   # 派单提醒工程师
SMS_TEMPLATE_CODE_SIGN=       # 客户签字提醒
SMS_TEMPLATE_CODE_REPORT=     # 报告完成通知
SMS_TEMPLATE_CODE_VERIFY=     # 客户登录验证码
SMS_MOCK=true                 # 设为 false 才会真实发短信，开发期先留 true

# 阶段二：微信配置（小程序 + 云服务通知）
# 登录 https://mp.weixin.qq.com/ 获取
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_TOKEN=
WECHAT_ENCODING_KEY=
WECHAT_MOCK=true              # 设为 false 才会真实调用微信 API

# 阶段二：客户门户配置
CUSTOMER_PORTAL_URL=http://localhost:3001   # 客户 H5 页面地址（短信中的跳转链接）
CUSTOMER_JWT_SECRET=customer_portal_secret_key_2024
